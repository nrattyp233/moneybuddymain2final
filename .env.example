#######################################################################
# MoneyBuddy (Vite) environment variables
#
# - For Vercel: add these in Project → Settings → Environment Variables
# - For local dev: copy to `.env.local` (never commit `.env.local`)
#
# IMPORTANT:
# - Only variables prefixed with VITE_ are exposed to the browser.
# - Do NOT put secrets (Stripe secret key, Supabase service role key, DB passwords)
#   in VITE_ variables.
#######################################################################

############################
# Frontend (browser) config #
############################

# Supabase project URL (public)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase anon key (public)
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Stripe publishable key (public)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Gemini API key (optional; used by `geminiService.ts`)
VITE_GEMINI_API_KEY="YOUR_GEMINI_KEY"

############################################
# Vercel Serverless API (server-only) vars  #
# (Only needed if you use `/api/stripe/*`)  #
############################################

# Stripe secret key (server secret)
STRIPE_SECRET_KEY="sk_test_..."

# Supabase service role key (server secret)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

##########################################
# Supabase Edge Functions (set in Supabase)
# Project Settings → Functions → Env Vars
#
# These do NOT come from Vercel automatically.
##########################################

# PLAID_ENV="development"
# STRIPE_ENV="development"
# PLAID_CLIENT_ID="..."
# PLAID_SECRET="..."
# STRIPE_SECRET_KEY="sk_test_..."
# SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
