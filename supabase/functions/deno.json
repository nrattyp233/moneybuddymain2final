{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "allowJs": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["deno.ns"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
